// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  PRODUCER
  AFFILIATE
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CommissionStatus {
  PENDING
  PAID
  REJECTED
  CANCELED
}

// auth.user → Profile
model Profile {
  id        String   @id
  username  String?  @unique
  role      Role
  createdAt DateTime @default(now())

  gamifications Gamification[]
  enrollments   Enrollment[]
  commissions   Commission[]
  orders        Order[]
  affiliations  Affiliation[]
  products      Product[]
}

// Representa cursos o productos digitales.
model Product {
  id          String        @id @default(uuid())
  title       String
  description String
  price       Float
  producerId  String
  status      ProductStatus
  createdAt   DateTime      @default(now())

  producer Profile @relation(fields: [producerId], references: [id])

  affiliations Affiliation[]
  orders       Order[]
  enrollments  Enrollment[]
}

// Relación afiliado ↔ producto.
model Affiliation {
  id           String @id @default(uuid())
  productId    String
  affiliateId  String
  commissionId String
  code         String @unique

  affiliate Profile @relation(fields: [affiliateId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  commissions Commission[]
}

// Registro de compras
model Order {
  id        String   @id @default(uuid())
  productId String
  buyerId   String
  total     Float
  createdAt DateTime @default(now())

  buyer       Profile      @relation(fields: [buyerId], references: [id])
  product     Product      @relation(fields: [productId], references: [id])
  commissions Commission[]
}

// Para calcular ingresos de los afiliados
model Commission {
  id            String           @id @default(uuid())
  profileId     String?
  orderId       String
  affiliationId String
  amount        Float
  status        CommissionStatus

  order       Order       @relation(fields: [orderId], references: [id])
  affiliation Affiliation @relation(fields: [affiliationId], references: [id])
  profile     Profile?    @relation(fields: [profileId], references: [id])
}

// Tabla simple de progreso
model Gamification {
  userId    String   @id
  xp        Int
  level     Int
  createdAt DateTime @default(now())

  user Profile @relation(fields: [userId], references: [id])
}

// Progreso del curso (solo si hay contenido)
model Enrollment {
  id        String @id @default(uuid())
  productId String
  userId    String
  progress  Int

  user    Profile @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

