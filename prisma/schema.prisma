generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profiles {
  id            String         @id
  username      String?        @unique
  role          Role           @default(STUDENT)
  createdAt     DateTime       @default(now())
  avatar        String?
  bio           String?
  fullname      String?
  phone         String?
  email         String         @unique
  affiliations  Affiliations[]
  commissions   Commissions[]
  enrollments   Enrollments[]
  gamifications Gamifications?
  orders        Orders[]
  products      Products[]

  @@map("Profiles")
}

model Products {
  id           String         @id @default(uuid())
  title        String
  description  String
  price        Float
  producerId   String
  status       ProductStatus  @default(DRAFT)
  createdAt    DateTime       @default(now())
  affiliations Affiliations[]
  enrollments  Enrollments[]
  orders       Orders[]
  producer     Profiles       @relation(fields: [producerId], references: [id])
}

model Affiliations {
  id           String        @id @default(uuid())
  productId    String
  affiliateId  String
  commissionId String
  code         String        @unique
  affiliate    Profiles      @relation(fields: [affiliateId], references: [id])
  product      Products      @relation(fields: [productId], references: [id])
  commissions  Commissions[]
}

model Orders {
  id          String        @id @default(uuid())
  productId   String
  buyerId     String
  total       Float
  createdAt   DateTime      @default(now())
  commissions Commissions[]
  buyer       Profiles      @relation(fields: [buyerId], references: [id])
  product     Products      @relation(fields: [productId], references: [id])
}

model Commissions {
  id            String           @id @default(uuid())
  profileId     String?
  orderId       String
  affiliationId String
  amount        Float
  status        CommissionStatus
  affiliation   Affiliations     @relation(fields: [affiliationId], references: [id])
  order         Orders           @relation(fields: [orderId], references: [id])
  profile       Profiles?        @relation(fields: [profileId], references: [id])
}

model Gamifications {
  userId    String   @id
  xp        Int
  level     Int
  createdAt DateTime @default(now())
  user      Profiles @relation(fields: [userId], references: [id])
}

model Enrollments {
  id        String   @id @default(uuid())
  productId String
  userId    String
  progress  Int
  product   Products @relation(fields: [productId], references: [id])
  user      Profiles @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

enum Role {
  STUDENT
  PRODUCER
  AFFILIATE
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CommissionStatus {
  PENDING
  PAID
  REJECTED
  CANCELED
}
