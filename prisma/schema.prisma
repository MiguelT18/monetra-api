// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  PRODUCER
  AFFILIATE
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CommissionStatus {
  PENDING
  PAID
  REJECTED
  CANCELED
}

// auth.user → Profile
model Profiles {
  id        String   @id
  role      Role     @default(STUDENT)
  username  String?  @unique
  fullname  String?
  bio       String?
  avatar    String?
  phone     String?
  createdAt DateTime @default(now())

  gamifications Gamifications[]
  enrollments   Enrollments[]
  commissions   Commissions[]
  orders        Orders[]
  affiliations  Affiliations[]
  products      Products[]

  @@map("Profiles")
}

// Representa cursos o productos digitales.
model Products {
  id          String        @id @default(uuid())
  title       String
  description String
  price       Float
  producerId  String
  status      ProductStatus
  createdAt   DateTime      @default(now())

  producer Profiles @relation(fields: [producerId], references: [id])

  affiliations Affiliations[]
  orders       Orders[]
  enrollments  Enrollments[]
}

// Relación afiliado ↔ producto.
model Affiliations {
  id           String @id @default(uuid())
  productId    String
  affiliateId  String
  commissionId String
  code         String @unique

  product   Products @relation(fields: [productId], references: [id])
  affiliate Profiles @relation(fields: [affiliateId], references: [id])

  commissions Commissions[]
}

// Registro de compras
model Orders {
  id        String   @id @default(uuid())
  productId String
  buyerId   String
  total     Float
  createdAt DateTime @default(now())

  buyer       Profiles      @relation(fields: [buyerId], references: [id])
  product     Products      @relation(fields: [productId], references: [id])
  commissions Commissions[]
}

// Para calcular ingresos de los afiliados
model Commissions {
  id            String           @id @default(uuid())
  profileId     String?
  orderId       String
  affiliationId String
  amount        Float
  status        CommissionStatus

  order       Orders       @relation(fields: [orderId], references: [id])
  affiliation Affiliations @relation(fields: [affiliationId], references: [id])
  profile     Profiles?    @relation(fields: [profileId], references: [id])
}

// Tabla simple de progreso
model Gamifications {
  userId    String   @id
  xp        Int
  level     Int
  createdAt DateTime @default(now())

  user Profiles @relation(fields: [userId], references: [id])
}

// Progreso del curso (solo si hay contenido)
model Enrollments {
  id        String @id @default(uuid())
  productId String
  userId    String
  progress  Int

  user    Profiles @relation(fields: [userId], references: [id])
  product Products @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

